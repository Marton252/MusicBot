# ═══════════════════════════════════════════════════════════════════
# Lavalink v4 configuration for Discord Music Bot
#
# This file is mounted by docker-compose.example.yml.
# LAVALINK_PORT and LAVALINK_PASSWORD are read from .env.
# ═══════════════════════════════════════════════════════════════════

server:
  port: ${LAVALINK_PORT:2333}
  address: 0.0.0.0
  http2:
    enabled: false

lavalink:
  plugins:
    # Lavalink v4 deprecates the built-in YouTube source.
    # Keep this plugin pinned and update intentionally.
    - dependency: "dev.lavalink.youtube:youtube-plugin:1.17.0"
      snapshot: false

  server:
    password: "${LAVALINK_PASSWORD:change_me}"

    sources:
      youtube: false
      bandcamp: true
      soundcloud: true
      twitch: false
      vimeo: true
      nico: false
      http: true
      local: false

    filters:
      volume: true
      equalizer: true
      karaoke: true
      timescale: true
      tremolo: true
      vibrato: true
      distortion: true
      rotation: true
      channelMix: true
      lowPass: true

    # Conservative defaults for stable Discord music playback.
    bufferDurationMs: 400
    frameBufferDurationMs: 5000
    opusEncodingQuality: 10
    resamplingQuality: LOW
    trackStuckThresholdMs: 10000
    useSeekGhosting: true
    youtubePlaylistLoadLimit: 6
    playerUpdateInterval: 5
    youtubeSearchEnabled: true
    soundcloudSearchEnabled: true
    soundcloudFilterOutPreviewTracks: false

plugins:
  youtube:
    enabled: true
    allowSearch: true
    allowDirectVideoIds: true
    allowDirectPlaylistIds: true

    # MUSIC works well for playback; WEB/ANDROID_VR help with search and
    # direct links when YouTube changes client behavior.
    clients:
      - MUSIC
      - WEB
      - ANDROID_VR

logging:
  level:
    root: INFO
    lavalink: INFO
