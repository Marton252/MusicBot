# ═══════════════════════════════════════════════════════════════════
# Discord Music Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ─── Discord ──────────────────────────────────────────────────────
# Required. Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_client_id_here

# Optional. Restrict command sync to a single guild during development.
# Leave empty or "null" for multi-guild mode.
GUILD_ID=

# ─── Spotify API (Optional) ──────────────────────────────────────
# Enables Spotify link resolution. Get credentials from
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Genius Lyrics API (Optional) ────────────────────────────────
# Enables the /lyrics command and Lyrics button.
# Get your access token from https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# ─── Bot Appearance ──────────────────────────────────────────────
EMBED_COLOR=#8000FF
STATUS=🎵 Music Bot | /play

# Timezone for timestamps in embeds and Docker container.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
BOT_TIMEZONE=UTC

# Optional links displayed in /help. Leave empty to hide them.
WEBSITE=
SUPPORT_SERVER=

# ─── Owner & Reporting ───────────────────────────────────────────
# Your Discord user ID. Reports will be DM'd here if no channel is set.
OWNER_ID=

# Optional. A channel ID where reports will be sent instead of DMs.
REPORT_CHANNEL_ID=

# ─── Database ────────────────────────────────────────────────────
DATABASE_PATH=database.db

# ─── Sharding (1000+ servers) ────────────────────────────────────
# Leave as "auto" for automatic configuration.
TOTAL_SHARDS=auto

# ─── YouTube Cookies (Optional) ──────────────────────────────────
# Helps bypass YouTube bot-detection. Pick ONE method:

# Method 1: Extract from your browser (recommended)
# Options: chrome, firefox, edge, safari, opera
COOKIES_FROM_BROWSER=

# Method 2: Path to a Netscape-format cookies.txt file
COOKIES_FILE=

# ─── Web Dashboard ───────────────────────────────────────────────
# Admin credentials for the dashboard. Additional users can be
# managed from the dashboard UI after logging in as admin.
DASHBOARD_PORT=25825
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Bind address. Use 127.0.0.1 for local-only, 0.0.0.0 for remote access.
DASHBOARD_BIND=127.0.0.1

# Secret key for cookie signing & password encryption.
# Generate with: python -c "import secrets,string; a=string.ascii_letters+string.digits+'!@#$%%^&*_+-='; print(''.join(secrets.choice(a) for _ in range(48)))"
# If not set, a random key is generated on each restart (sessions won't persist).
DASHBOARD_SECRET_KEY=

# SSL certificate paths (generate with: py generate_cert.py)
SSL_CERT_PATH=certs/cert.pem
SSL_KEY_PATH=certs/key.pem
